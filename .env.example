# ═══════════════════════════════════════════════════════════
# AfriMine AI — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════
# SECURITY: Never commit .env files. They are in .gitignore.
# Set file permissions: chmod 600 .env

# ── App ──────────────────────────────────────────────────
APP_NAME=AfriMineAI
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug
LOG_FORMAT=json

# ── Database (Supabase) ──────────────────────────────────
# SECURITY: Use strong passwords. Never use default credentials in production.
SUPABASE_URL=https://owjepykjcjrhtjeilmfp.supabase.co
SUPABASE_ANON_KEY=<paste-your-anon-key-here>
SUPABASE_SERVICE_KEY=<paste-your-service-role-key-here>
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── AI / LLM APIs ────────────────────────────────────────
# SECURITY: Rotate API keys regularly. Use separate keys per environment.
# Primary: NVIDIA NIM (free tier on build.nvidia.com)
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimax/minimax-m3
# Backup providers (fallback chain: NVIDIA → Groq → Mistral → Ollama)
GROQ_API_KEY=your-groq-key
MISTRAL_API_KEY=your-mistral-key
# Local/offline (optional, requires Ollama running on Jetson or local machine)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.3:70b

# ── Google Earth Engine ──────────────────────────────────
GEE_PROJECT_ID=your-gcp-project-id
GEE_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com
GEE_PRIVATE_KEY_PATH=/path/to/service-account.json

# ── Cloudflare ───────────────────────────────────────────
CLOUDFLARE_API_TOKEN=your-cf-api-token
CLOUDFLARE_ACCOUNT_ID=your-cf-account-id
CLOUDFLARE_PAGES_PROJECT=afrimine-ai

# ── Render.com ───────────────────────────────────────────
RENDER_API_KEY=your-render-api-key
RENDER_DEPLOY_HOOK_BACKEND=https://api.render.com/deploy/srv-xxx
RENDER_DEPLOY_HOOK_AI_ENGINE=https://api.render.com/deploy/srv-yyy

# ── Auth ─────────────────────────────────────────────────
# SECURITY: JWT_SECRET must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48
JWT_EXPIRY=24h

# ── Sentry (Error Tracking) ─────────────────────────────
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── File Storage ─────────────────────────────────────────
STORAGE_BUCKET=afrimine-samples
MAX_UPLOAD_SIZE_MB=20

# ── Uptime Monitoring ────────────────────────────────────
UPTIMEROBOT_API_KEY=your-uptimerobot-api-key
HEALTH_CHECK_URL=https://api.afrimine.ai/health
